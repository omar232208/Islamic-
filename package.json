{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"var p=require('path'),f=['package-lock.json','yarn.lock'];f.forEach(function(x){try{require('fs').unlinkSync(p.join(process.cwd(),x))}catch(e){}});var ua=process.env.npm_config_user_agent||'';if(ua.indexOf('pnpm')===-1){console.error('Use pnpm please');process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.1"
  },
  "devDependencies": {
    "prettier": "^3.9.5",
    "typescript": "~5.9.3"
  }
}
