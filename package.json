{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"var p=require('path'),f=['package-lock.json','yarn.lock'];f.forEach(function(x){try{require('fs').unlinkSync(p.join(process.cwd(),x))}catch(e){}});var ua=process.env.npm_config_user_agent||'';if(ua.indexOf('pnpm')===-1){console.error('Use pnpm please');process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.1"
  },
  "devDependencies": {
    "expo": "~54.0.27",
    "expo-router": "~6.0.17",
    "expo-font": "~14.0.10",
    "expo-web-browser": "~15.0.10",
    "expo-constants": "~18.0.11",
    "expo-status-bar": "~3.0.9",
    "expo-linking": "~8.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-screens": "~4.16.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-worklets": "0.5.1",
    "react-native-svg": "15.12.1",
    "prettier": "^3.9.5",
    "typescript": "~5.9.3"
  }
}
